{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@qodalis/cli-server-plugin-filesystem": ["../filesystem/dist"]
        }
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
