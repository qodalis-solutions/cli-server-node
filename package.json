{
    "name": "@qodalis/cli-server-node",
    "version": "1.0.0-beta.5",
    "description": "Node.js CLI server for Qodalis CLI ecosystem — use as a library in existing Express apps or run standalone",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "bin": {
        "qodalis-cli-server": "dist/src/server.js"
    },
    "files": [
        "dist",
        "!dist/src/__tests__",
        "!dist/plugins",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "start": "tsx src/server.ts",
        "dev": "tsx watch src/server.ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "cli",
        "qodalis",
        "terminal",
        "commands",
        "cli-server",
        "command-processor"
    ],
    "author": "Nicolae Lupei <nicolae.lupei@qodalis.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/qodalis-solutions/cli-server-node"
    },
    "homepage": "https://qodalis.com/",
    "dependencies": {
        "@qodalis/cli-server-abstractions": "file:packages/abstractions",
        "@qodalis/cli-server-plugin-data-explorer": "file:plugins/data-explorer",
        "@qodalis/cli-server-plugin-filesystem": "file:plugins/filesystem",
        "@qodalis/cli-server-plugin-jobs": "file:plugins/jobs",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "multer": "^2.1.0",
        "node-pty": "^1.1.0",
        "ws": "^8.18.0"
    },
    "optionalDependencies": {
        "@elastic/elasticsearch": "^8.16.0",
        "@qodalis/cli-server-plugin-filesystem-json": "file:plugins/filesystem-json",
        "@qodalis/cli-server-plugin-filesystem-s3": "file:plugins/filesystem-s3",
        "@qodalis/cli-server-plugin-filesystem-sqlite": "file:plugins/filesystem-sqlite",
        "better-sqlite3": "^11.10.0",
        "ioredis": "^5.4.0",
        "mongodb": "^6.0.0",
        "mssql": "^11.0.0",
        "mysql2": "^3.11.0",
        "pg": "^8.13.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/mssql": "^9.1.9",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.0.0",
        "@types/supertest": "^7.2.0",
        "@types/ws": "^8.5.13",
        "supertest": "^7.2.2",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitest": "^4.0.18"
    }
}
