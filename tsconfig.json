{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "paths": {
            "@qodalis/cli-server-plugin-filesystem": ["./plugins/filesystem/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-json": ["./plugins/filesystem-json/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-sqlite": ["./plugins/filesystem-sqlite/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-s3": ["./plugins/filesystem-s3/index.ts"],
            "@qodalis/cli-server-plugin-jobs": ["./plugins/jobs/index.ts"],
            "@qodalis/cli-server-plugin-weather": ["./plugins/weather/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer": ["./plugins/data-explorer/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-sql": ["./plugins/data-explorer-sql/index.ts"],
            "@qodalis/cli-server-plugin-aws": ["./plugins/aws/src/index.ts"]
        }
    },
    "include": ["src/**/*", "plugins/**/*"],
    "exclude": ["node_modules", "dist", "src/__tests__", "plugins/**/__tests__", "plugins/**/*.test.ts", "plugins/aws", "plugins/admin"]
}
