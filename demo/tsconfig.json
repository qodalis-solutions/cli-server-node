{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "paths": {
            "@qodalis/cli-server-node": ["../src/index.ts"],
            "@qodalis/cli-server-abstractions": ["../packages/abstractions/src/index.ts"],
            "@qodalis/cli-server-plugin-filesystem": ["../plugins/filesystem/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-json": ["../plugins/filesystem-json/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-sqlite": ["../plugins/filesystem-sqlite/index.ts"],
            "@qodalis/cli-server-plugin-filesystem-s3": ["../plugins/filesystem-s3/index.ts"],
            "@qodalis/cli-server-plugin-jobs": ["../plugins/jobs/index.ts"],
            "@qodalis/cli-server-plugin-weather": ["../plugins/weather/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-sql": ["../plugins/data-explorer-sql/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-mongo": ["../plugins/data-explorer-mongo/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-postgres": ["../plugins/data-explorer-postgres/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-mysql": ["../plugins/data-explorer-mysql/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-mssql": ["../plugins/data-explorer-mssql/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-redis": ["../plugins/data-explorer-redis/index.ts"],
            "@qodalis/cli-server-plugin-data-explorer-elasticsearch": ["../plugins/data-explorer-elasticsearch/index.ts"],
            "@qodalis/cli-server-plugin-admin": ["../plugins/admin/index.ts"],
            "@qodalis/cli-server-plugin-aws": ["../plugins/aws/src/index.ts"]
        }
    },
    "include": ["src/**/*"]
}
